model WorkAssignment {
  id                     String                 @id @default(cuid())
  companyId              String
  workScheduleId         String
  columnIndex            Int
  label                  String
  locationType           AssignmentLocationType @default(SITE_JOB)
  jobId                  String?
  factoryCode            String?
  factoryLabel           String?
  jobNumberSnapshot      String?
  siteNameSnapshot       String?
  clientNameSnapshot     String?
  projectDetailsSnapshot String?                @db.Text
  teamLeaderEmployeeId   String?
  driver1EmployeeId      String?
  driver2EmployeeId      String?
  shiftStart             String?
  shiftEnd               String?
  breakWindow            String?
  targetQty              Decimal?               @db.Decimal(18, 3)
  achievedQty            Decimal?               @db.Decimal(18, 3)
  unit                   String?
  remarks                String?                @db.Text
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  company           Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workSchedule      WorkSchedule           @relation(fields: [companyId, workScheduleId], references: [companyId, id], onDelete: Cascade)
