  leaveRequest   LeaveRequest?   @relation(fields: [leaveRequestId], references: [id], onDelete: SetNull)
  leaveTypeRef   LeaveType?      @relation(fields: [companyId, leaveTypeId], references: [companyId, id], onDelete: Restrict)

