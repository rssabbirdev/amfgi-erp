  payType    PayType             @relation(fields: [companyId, payTypeId], references: [companyId, id], onDelete: Restrict)
  visaPeriod VisaPeriod?         @relation(fields: [companyId, visaPeriodId], references: [companyId, id], onDelete: SetNull)
  allowances EmployeeAllowance[]

  @@unique([companyId, id])
  @@index([companyId, employeeId])
  @@index([companyId, payTypeId])
  @@index([companyId, visaPeriodId])
  @@index([companyId, effectiveFrom])
