model AttendanceEntry {
  id                 String                   @id @default(cuid())
  companyId          String
  employeeId         String
  workDate           DateTime                 @db.Date
  workAssignmentId   String?
  checkInAt          DateTime?
  checkOutAt         DateTime?
  breakStartAt       DateTime?
  breakEndAt         DateTime?
  status             AttendanceEntryStatus    @default(PRESENT)
  /// Snapshot of basic duty hours for this day (from employee type settings at create time)
  basicHours         Decimal                  @default(8) @db.Decimal(4, 2)
  leaveType          AttendanceLeaveType?
  leaveTypeId        String?
  lateMinutes        Int                      @default(0)
  earlyLeaveMinutes  Int                      @default(0)
  overtimeMinutes    Int                      @default(0)
  workflowStatus     AttendanceWorkflowStatus @default(DRAFT)
  source             AttendanceSource         @default(SCHEDULE_BOILERPLATE)
  leaveRequestId     String?
  remarks            String?                  @db.Text
  approvedById       String?
  approvedAt         DateTime?
