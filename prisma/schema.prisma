generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Company {
  id                    String                 @id @default(cuid())
  name                  String                 @unique
  slug                  String                 @unique
  /// Stable id shared by external Project Management system
  externalCompanyId     String?                @unique
  /// HYBRID = local + external parent jobs, EXTERNAL_ONLY = parent jobs from API only
  jobSourceMode         JobSourceMode          @default(HYBRID)
  description           String?                @db.Text
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  address               String?                @db.Text
  email                 String?
  letterheadDriveId     String?
  letterheadUrl         String?
  printTemplates        Json?
  hrEmployeeTypeSettings Json?
  phone                 String?
  categories            Category[]
  customers             Customer[]
  jobs                  Job[]
  materials             Material[]
  stockBatches          StockBatch[]
  suppliers             Supplier[]
  transactions          Transaction[]
  units                 Unit[]
  materialUoms          MaterialUom[]
  activeForUsers        User[]                 @relation("UserActiveCompany")
  users                 UserCompanyAccess[]
  warehouses            Warehouse[]
  mediaAssets           MediaAsset[]
  apiCredentials        ApiCredential[]
  lpoValueChanges       JobLpoValueHistory[]
  integrationLogs       IntegrationSyncLog[]
  employees             Employee[]
  employeeDocumentTypes EmployeeDocumentType[]
  workSchedules         WorkSchedule[]
  attendanceEntries     AttendanceEntry[]
  visaPeriods           VisaPeriod[]
  employeeDocuments     EmployeeDocument[]
  workforceExpertises   WorkforceExpertise[]
}

model User {
  id               String              @id @default(cuid())
  name             String
  email            String              @unique
  password         String?
  /**
   * Display URL (e.g. lh3); prefer resolving from imageDriveId when set
   */
  image            String?
  /**
   * Google Drive file id for profile photo — source of truth for display
   */
  imageDriveId     String?
  /**
   * Legacy / cache; prefer signatureDriveId + lh3 for display
   */
  signatureUrl     String?             @db.Text
  signatureDriveId String?
  isSuperAdmin     Boolean             @default(false)
  isActive         Boolean             @default(true)
  activeCompanyId  String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  activeCompany    Company?            @relation("UserActiveCompany", fields: [activeCompanyId], references: [id])
  companyAccess    UserCompanyAccess[]
  uploadedMedia    MediaAsset[]        @relation("MediaAssetUploader")
  /// When set, this login is the employee self-service account for HR portal
  linkedEmployeeId String?             @unique
  linkedEmployee   Employee?           @relation("EmployeeUserLink", fields: [linkedEmployeeId], references: [id], onDelete: SetNull)

  @@index([activeCompanyId])
}

/// Uploaded file stored in Google Drive; usage tracked via MediaAssetLink (orphans = safe to delete).
model MediaAsset {
  id           String           @id @default(cuid())
  companyId    String
  driveId      String
  mimeType     String           @default("image/jpeg")
  fileName     String
  /// e.g. profile_image, signature, template, general
  category     String           @default("general")
  bytes        Int?
  uploadedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy   User?            @relation("MediaAssetUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  links        MediaAssetLink[]

  @@unique([companyId, driveId])
  @@index([companyId, category])
  @@index([companyId, createdAt])
}

/// Binds a media file to an app entity (one profile image per user, etc.).
model MediaAssetLink {
  id       String     @id @default(cuid())
  assetId  String
  kind     String
  entityId String
  asset    MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([kind, entityId])
  @@index([assetId])
}

model Role {
  id          String              @id @default(cuid())
  name        String              @unique
  slug        String              @unique
  permissions Json
  isSystem    Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  userAccess  UserCompanyAccess[]
}

model UserCompanyAccess {
  id        String  @id @default(cuid())
  userId    String
  companyId String
  roleId    String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role    @relation(fields: [roleId], references: [id])
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([roleId])
}

model Material {
  id               String        @id @default(cuid())
  companyId        String
  name             String
  description      String?       @db.Text
  unit             String
  category         String?
  warehouse        String?
  stockType        String
  externalItemName String?
  currentStock     Float         @default(0)
  reorderLevel     Float?
  unitCost         Float?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockBatches     StockBatch[]
  transactions     Transaction[]
  materialUoms     MaterialUom[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

/// Per-material UOM chain: exactly one base (parent null, factor 1). 1 of this row = factorToParent × 1 parent UOM.
model MaterialUom {
  id             String        @id @default(cuid())
  companyId      String
  materialId     String
  unitId         String
  isBase         Boolean       @default(false)
  parentUomId    String?
  factorToParent Float
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  material       Material      @relation(fields: [materialId], references: [id], onDelete: Cascade)
  unit           Unit          @relation(fields: [unitId], references: [id], onDelete: Restrict)
  parent         MaterialUom?  @relation("MaterialUomParent", fields: [parentUomId], references: [id], onDelete: Restrict)
  children       MaterialUom[] @relation("MaterialUomParent")

  @@unique([materialId, unitId])
  @@index([companyId, materialId])
}

model StockBatch {
  id                String             @id @default(cuid())
  companyId         String
  materialId        String
  batchNumber       String
  quantityReceived  Float
  quantityAvailable Float
  unitCost          Float
  totalCost         Float
  supplier          String?
  supplierId        String?
  receiptNumber     String?
  receivedDate      DateTime
  expiryDate        DateTime?
  notes             String?            @db.Text
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  material          Material           @relation(fields: [materialId], references: [id])
  supplierRef       Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  transactionLinks  TransactionBatch[]

  @@unique([companyId, batchNumber])
  @@index([companyId, materialId, receivedDate])
  @@index([companyId, materialId, quantityAvailable])
  @@index([receiptNumber])
  @@index([supplierId])
  @@index([materialId], map: "StockBatch_materialId_fkey")
}

model Transaction {
  id                  String             @id @default(cuid())
  companyId           String
  type                TransactionType
  materialId          String
  quantity            Float
  jobId               String?
  parentTransactionId String?
  counterpartCompany  String?
  notes               String?            @db.Text
  date                DateTime           @default(now())
  performedBy         String
  totalCost           Float              @default(0)
  averageCost         Float              @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  isDeliveryNote      Boolean            @default(false)
  signedCopyDriveId   String?
  signedCopyUrl       String?
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job                 Job?               @relation(fields: [jobId], references: [id])
  material            Material           @relation(fields: [materialId], references: [id])
  parent              Transaction?       @relation("TxParent", fields: [parentTransactionId], references: [id])
  children            Transaction[]      @relation("TxParent")
  batchesUsed         TransactionBatch[]

  @@index([companyId, date])
  @@index([companyId, jobId, materialId])
  @@index([companyId, materialId, type])
  @@index([parentTransactionId])
  @@index([jobId], map: "Transaction_jobId_fkey")
  @@index([materialId], map: "Transaction_materialId_fkey")
}

model TransactionBatch {
  id                String      @id @default(cuid())
  transactionId     String
  batchId           String
  batchNumber       String
  quantityFromBatch Float
  unitCost          Float
  costAmount        Float
  batch             StockBatch  @relation(fields: [batchId], references: [id])
  transaction       Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([batchId])
}

model Job {
  id                String               @id @default(cuid())
  companyId         String
  /// External parent-job identifier from Project Management system
  externalJobId     String?
  jobNumber         String
  customerId        String
  description       String?              @db.Text
  site              String?
  address           String?              @db.Text
  locationName      String?
  locationLat       Float?
  locationLng       Float?
  status            JobStatus            @default(ACTIVE)
  startDate         DateTime?
  endDate           DateTime?
  quotationNumber   String?
  quotationDate     DateTime?
  lpoNumber         String?
  lpoDate           DateTime?
  lpoValue          Float?
  projectName       String?
  projectDetails    String?              @db.Text
  /// Primary site/contact name (same idea as Customer.contactPerson)
  contactPerson     String?
  contactsJson      Json?
  salesPerson       String?
  jobWorkValue      Float?
  finishedGoods     Json?
  requiredExpertises Json?
  source            JobRecordSource      @default(LOCAL)
  externalUpdatedAt DateTime?
  createdBy         String
  parentJobId       String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer          Customer             @relation(fields: [customerId], references: [id])
  parentJob         Job?                 @relation("JobVariations", fields: [parentJobId], references: [id], onDelete: Cascade)
  variations        Job[]                @relation("JobVariations")
  transactions      Transaction[]
  lpoValueHistory   JobLpoValueHistory[]
  workAssignments   WorkAssignment[]

  @@unique([companyId, jobNumber])
  @@unique([companyId, externalJobId])
  @@index([companyId, status])
  @@index([customerId])
  @@index([parentJobId])
  @@index([companyId, source])
}

model WorkforceExpertise {
  id        String   @id @default(cuid())
  companyId String
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId, isActive, sortOrder])
}

/// One-way inbound credential for integrations; only hash is stored.
model ApiCredential {
  id             String    @id @default(cuid())
  companyId      String
  label          String
  keyPrefix      String
  keyHash        String
  /// Hostnames allowed to call integration APIs (Origin / Referer). Empty = no restriction.
  allowedDomains Json?
  scopes         Json?
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, keyPrefix])
  @@index([companyId, revokedAt])
}

/// Audit trail for LPO value changes (manual or external sync).
model JobLpoValueHistory {
  id            String   @id @default(cuid())
  companyId     String
  jobId         String
  previousValue Float?
  newValue      Float?
  changedBy     String
  source        String   @default("manual")
  note          String?
  createdAt     DateTime @default(now())
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([jobId, createdAt])
}

model IntegrationSyncLog {
  id             String   @id @default(cuid())
  companyId      String
  credentialId   String?
  idempotencyKey String?
  requestHash    String?
  direction      String   @default("inbound")
  entityType     String   @default("job")
  entityKey      String?
  status         String   @default("success")
  httpStatus     Int?
  requestBody    Json?
  responseBody   Json?
  errorMessage   String?  @db.Text
  createdAt      DateTime @default(now())
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, idempotencyKey])
  @@index([companyId, createdAt])
  @@index([companyId, status])
  @@index([credentialId])
}

model Customer {
  id                    String            @id @default(cuid())
  companyId             String
  name                  String
  contactPerson         String?
  phone                 String?
  email                 String?
  address               String?           @db.Text
  isActive              Boolean           @default(true)
  /// Created in AMFGI vs imported from external party-lists API
  source                PartyRecordSource @default(LOCAL)
  /// Remote party id from Accounts Helper (clients.php id) when source = PARTY_API_SYNC
  externalPartyId       Int?
  externalSyncedAt      DateTime?
  tradeLicenseNumber    String?
  tradeLicenseAuthority String?           @db.VarChar(255)
  tradeLicenseExpiry    DateTime?
  trnNumber             String?
  trnExpiry             DateTime?
  contactsJson          Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  company               Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs                  Job[]

  @@unique([companyId, externalPartyId])
  @@index([companyId, name])
  @@index([companyId, isActive])
  @@index([companyId, source])
}

model Supplier {
  id                    String            @id @default(cuid())
  companyId             String
  name                  String
  contactPerson         String?
  email                 String?
  phone                 String?
  address               String?           @db.Text
  city                  String?
  country               String?
  isActive              Boolean           @default(true)
  source                PartyRecordSource @default(LOCAL)
  externalPartyId       Int?
  externalSyncedAt      DateTime?
  tradeLicenseNumber    String?
  tradeLicenseAuthority String?           @db.VarChar(255)
  tradeLicenseExpiry    DateTime?
  trnNumber             String?
  trnExpiry             DateTime?
  contactsJson          Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  company               Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockBatches          StockBatch[]

  @@unique([companyId, externalPartyId])
  @@index([companyId, name])
  @@index([companyId, isActive])
  @@index([companyId, source])
}

model Unit {
  id           String        @id @default(cuid())
  companyId    String
  name         String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  materialUoms MaterialUom[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model Category {
  id        String   @id @default(cuid())
  companyId String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model Warehouse {
  id        String   @id @default(cuid())
  companyId String
  name      String
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model MaterialLog {
  id         String            @id @default(cuid())
  companyId  String
  materialId String
  action     MaterialLogAction
  changes    Json
  changedBy  String
  timestamp  DateTime          @default(now())

  @@index([companyId, materialId, timestamp])
}

model PriceLog {
  id            String      @id @default(cuid())
  companyId     String
  materialId    String
  previousPrice Float
  currentPrice  Float
  source        PriceSource
  changedBy     String
  billId        String?
  notes         String?     @db.Text
  timestamp     DateTime    @default(now())

  @@index([companyId, materialId, timestamp])
}

// ── HR / Workforce (employees, schedule, attendance) ─────────────────────────

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  EXITED
}

enum VisaPeriodStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CANCELLED
}

enum WorkScheduleStatus {
  DRAFT
  PUBLISHED
  LOCKED
}

enum AssignmentLocationType {
  SITE_JOB
  FACTORY
  OTHER
}

enum AssignmentMemberRole {
  WORKER
  HELPER
  TEAM_LEADER
}

enum AttendanceEntryStatus {
  PRESENT
  ABSENT
  LEAVE
  HALF_DAY
  MISSING_PUNCH
}

enum AttendanceWorkflowStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

enum AttendanceSource {
  SCHEDULE_BOILERPLATE
  MANUAL
  IMPORT
}

model Employee {
  id                    String         @id @default(cuid())
  companyId             String
  employeeCode          String
  fullName              String
  preferredName         String?
  email                 String?
  phone                 String?
  nationality           String?
  dateOfBirth           DateTime?      @db.Date
  gender                String?
  designation           String?
  department            String?
  employmentType        String?
  hireDate              DateTime?      @db.Date
  terminationDate       DateTime?      @db.Date
  status                EmployeeStatus @default(ACTIVE)
  emergencyContactName  String?
  emergencyContactPhone String?
  bloodGroup            String?
  photoDriveId          String?
  portalEnabled         Boolean        @default(false)
  /// HR-only internal notes (lifetime record)
  adminNotes            String?        @db.Text
  /// Optional structured extra fields (JSON), e.g. custom key/value without migrations
  profileExtension      Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userLink              User?                  @relation("EmployeeUserLink")
  visaPeriods           VisaPeriod[]
  documents             EmployeeDocument[]
  assignmentMembers     WorkAssignmentMember[]
  scheduleAbsences      ScheduleAbsence[]
  driverRunLogs         DriverRunLog[]
  attendanceEntries     AttendanceEntry[]
  teamLeaderAssignments WorkAssignment[]       @relation("WorkAssignmentTeamLeader")
  driver1Assignments    WorkAssignment[]       @relation("WorkAssignmentDriver1")
  driver2Assignments    WorkAssignment[]       @relation("WorkAssignmentDriver2")

  @@unique([companyId, employeeCode])
  @@unique([companyId, email])
  @@index([companyId, status])
  @@index([companyId, fullName])
}

model VisaPeriod {
  id          String           @id @default(cuid())
  companyId   String
  employeeId  String
  label       String
  sponsorType String?
  visaType    String?
  startDate   DateTime         @db.Date
  endDate     DateTime         @db.Date
  status      VisaPeriodStatus @default(DRAFT)
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee  Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  documents EmployeeDocument[]

  @@index([companyId, employeeId])
  @@index([employeeId, status])
  @@index([companyId, endDate])
}

model EmployeeDocumentType {
  id                           String   @id @default(cuid())
  companyId                    String
  name                         String
  slug                         String
  requiresVisaPeriod           Boolean  @default(false)
  requiresExpiry               Boolean  @default(true)
  defaultAlertDaysBeforeExpiry Int      @default(30)
  sortOrder                    Int      @default(0)
  isActive                     Boolean  @default(true)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documents EmployeeDocument[]

  @@unique([companyId, slug])
  @@index([companyId, isActive])
}

model EmployeeDocument {
  id               String    @id @default(cuid())
  companyId        String
  employeeId       String
  visaPeriodId     String?
  documentTypeId   String
  documentNumber   String?
  issueDate        DateTime? @db.Date
  expiryDate       DateTime? @db.Date
  issuingAuthority String?
  notes            String?   @db.Text
  customFields     Json?
  mediaDriveId     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee     Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  visaPeriod   VisaPeriod?          @relation(fields: [visaPeriodId], references: [id], onDelete: SetNull)
  documentType EmployeeDocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)

  @@index([companyId, employeeId])
  @@index([companyId, expiryDate])
  @@index([documentTypeId])
}

model WorkSchedule {
  id                String             @id @default(cuid())
  companyId         String
  workDate          DateTime           @db.Date
  clientDisplayName String?
  title             String?
  notes             String?            @db.Text
  status            WorkScheduleStatus @default(DRAFT)
  publishedAt       DateTime?
  lockedAt          DateTime?
  createdById       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments WorkAssignment[]
  absences    ScheduleAbsence[]
  driverLogs  DriverRunLog[]

  @@unique([companyId, workDate])
  @@index([companyId, status])
}

model WorkAssignment {
  id                     String                 @id @default(cuid())
  workScheduleId         String
  columnIndex            Int
  label                  String
  locationType           AssignmentLocationType @default(SITE_JOB)
  jobId                  String?
  factoryCode            String?
  factoryLabel           String?
  jobNumberSnapshot      String?
  siteNameSnapshot       String?
  clientNameSnapshot     String?
  projectDetailsSnapshot String?                @db.Text
  teamLeaderEmployeeId   String?
  driver1EmployeeId      String?
  driver2EmployeeId      String?
  shiftStart             String?
  shiftEnd               String?
  breakWindow            String?
  targetQty              Float?
  achievedQty            Float?
  unit                   String?
  remarks                String?                @db.Text
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  workSchedule      WorkSchedule           @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)
  job               Job?                   @relation(fields: [jobId], references: [id], onDelete: SetNull)
  teamLeader        Employee?              @relation("WorkAssignmentTeamLeader", fields: [teamLeaderEmployeeId], references: [id], onDelete: SetNull)
  driver1           Employee?              @relation("WorkAssignmentDriver1", fields: [driver1EmployeeId], references: [id], onDelete: SetNull)
  driver2           Employee?              @relation("WorkAssignmentDriver2", fields: [driver2EmployeeId], references: [id], onDelete: SetNull)
  members           WorkAssignmentMember[]
  attendanceEntries AttendanceEntry[]

  @@unique([workScheduleId, columnIndex])
  @@index([workScheduleId])
  @@index([jobId])
}

model WorkAssignmentMember {
  id               String               @id @default(cuid())
  workAssignmentId String
  employeeId       String
  role             AssignmentMemberRole @default(WORKER)
  slot             Int                  @default(0)
  createdAt        DateTime             @default(now())

  workAssignment WorkAssignment @relation(fields: [workAssignmentId], references: [id], onDelete: Cascade)
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([workAssignmentId, employeeId])
  @@index([employeeId])
}

model ScheduleAbsence {
  id             String   @id @default(cuid())
  workScheduleId String
  employeeId     String
  reason         String?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())

  workSchedule WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([workScheduleId, employeeId])
  @@index([employeeId])
}

model DriverRunLog {
  id               String   @id @default(cuid())
  workScheduleId   String
  driverEmployeeId String
  routeText        String   @db.Text
  sequence         Int      @default(0)
  createdAt        DateTime @default(now())

  workSchedule WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)
  driver       Employee     @relation(fields: [driverEmployeeId], references: [id], onDelete: Cascade)

  @@index([workScheduleId])
  @@index([driverEmployeeId])
}

model AttendanceEntry {
  id                 String                   @id @default(cuid())
  companyId          String
  employeeId         String
  workDate           DateTime                 @db.Date
  workAssignmentId   String?
  expectedShiftStart DateTime?
  expectedShiftEnd   DateTime?
  checkInAt          DateTime?
  checkOutAt         DateTime?
  breakStartAt       DateTime?
  breakEndAt         DateTime?
  status             AttendanceEntryStatus    @default(PRESENT)
  lateMinutes        Int                      @default(0)
  earlyLeaveMinutes  Int                      @default(0)
  overtimeMinutes    Int                      @default(0)
  workflowStatus     AttendanceWorkflowStatus @default(DRAFT)
  source             AttendanceSource         @default(SCHEDULE_BOILERPLATE)
  approvedById       String?
  approvedAt         DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workAssignment WorkAssignment? @relation(fields: [workAssignmentId], references: [id], onDelete: SetNull)

  @@index([companyId, workDate])
  @@index([companyId, employeeId, workDate])
  @@index([workflowStatus])
}

