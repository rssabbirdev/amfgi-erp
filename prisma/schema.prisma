model Employee {
  id                    String         @id @default(cuid())
  companyId             String
  employeeCode          String
  fullName              String
  preferredName         String?
  email                 String?
  phone                 String?
  nationality           String?
  dateOfBirth           DateTime?      @db.Date
  gender                String?
  designation           String?
  department            String?
  employmentType        String?
  hireDate              DateTime?      @db.Date
  terminationDate       DateTime?      @db.Date
  status                EmployeeStatus @default(ACTIVE)
  emergencyContactName  String?
  emergencyContactPhone String?
  bloodGroup            String?
  photoUrl              String?
  portalEnabled         Boolean        @default(false)
  /// HR-only internal notes (lifetime record)
  adminNotes            String?        @db.Text
  /// Optional structured extra fields (JSON), e.g. custom key/value without migrations
  profileExtension      Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  company               Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userLink              User?                       @relation("EmployeeUserLink")
  visaPeriods           VisaPeriod[]
  documents             EmployeeDocument[]
  assignmentMembers     WorkAssignmentMember[]
  scheduleAbsences      ScheduleAbsence[]
  driverRunLogs         DriverRunLog[]
  attendanceEntries     AttendanceEntry[]
  mobileAccessTokens    EmployeeMobileAccessToken[]
  jobItemAssignments    JobItemAssignment[]
  teamLeaderAssignments WorkAssignment[]            @relation("WorkAssignmentTeamLeader")
  driver1Assignments    WorkAssignment[]            @relation("WorkAssignmentDriver1")
  driver2Assignments    WorkAssignment[]            @relation("WorkAssignmentDriver2")
  leaveRequests         LeaveRequest[]
  leaveBalances         LeaveBalance[]
  compensations         EmployeeCompensation[]
  allowances            EmployeeAllowance[]
  payRunLines           PayRunLine[]

  @@unique([companyId, id])
  @@unique([companyId, employeeCode])
  @@unique([companyId, email])
  @@index([companyId, status])
  @@index([companyId, fullName])
}

model VisaPeriod {
