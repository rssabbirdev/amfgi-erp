generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id                       String                      @id @default(cuid())
  name                     String                      @unique
  slug                     String                      @unique
  /// Stable id shared by external Project Management system
  externalCompanyId        String?                     @unique
  /// HYBRID = local + external parent jobs, EXTERNAL_ONLY = parent jobs from API only
  jobSourceMode            JobSourceMode               @default(HYBRID)
  customerSourceMode       PartyMasterSourceMode       @default(HYBRID)
  supplierSourceMode       PartyMasterSourceMode       @default(HYBRID)
  description              String?                     @db.Text
  isActive                 Boolean                     @default(true)
  jobCostingSettings       Json?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt
  address                  String?                     @db.Text
  email                    String?
  letterheadUrl            String?
  printTemplates           Json?
  hrEmployeeTypeSettings   Json?
  phone                    String?
  warehouseMode            WarehouseMode               @default(REQUIRED)
  stockFallbackWarehouseId String?
  onboardingStatus         CompanyOnboardingStatus     @default(NEW)
  foundationChecklist      Json?
  operationalSettings      Json?
  settingsVersion          Int                         @default(1)
  categories               Category[]
  customers                Customer[]
  customerContacts         CustomerContact[]
  jobs                     Job[]
  jobContacts              JobContact[]
  materials                Material[]
  stockBatches             StockBatch[]
  suppliers                Supplier[]
  supplierContacts         SupplierContact[]
  transactions             Transaction[]
  units                    Unit[]
  materialUoms             MaterialUom[]
  activeForUsers           User[]                      @relation("UserActiveCompany")
  users                    UserCompanyAccess[]
  warehouses               Warehouse[]                 @relation("CompanyWarehouses")
  stockFallbackWarehouse   Warehouse?                  @relation("CompanyStockFallbackWarehouse", fields: [id, stockFallbackWarehouseId], references: [companyId, id], onDelete: SetNull)
  mediaAssets              MediaAsset[]
  apiCredentials           ApiCredential[]
  lpoValueChanges          JobLpoValueHistory[]
  jobNumberHistory         JobNumberHistory[]
    integrationLogs          IntegrationSyncLog[]
  formulaLibraries         FormulaLibrary[]
  formulaLibraryVersions   FormulaLibraryVersion[]
  jobItems                 JobItem[]
  jobCostingSnapshots      JobCostingSnapshot[]
  jobItemAssignments       JobItemAssignment[]
  jobItemProgressEntries   JobItemProgressEntry[]
  jobItemTrackableMaterialLinks JobItemTrackableMaterialLink[]
  productionStockPostings  ProductionStockPosting[]
  jobRequiredExpertises    JobRequiredExpertise[]
  employees                Employee[]
  employeeDocumentTypes    EmployeeDocumentType[]
  workSchedules            WorkSchedule[]
  workAssignments          WorkAssignment[]
  workAssignmentMembers    WorkAssignmentMember[]
  scheduleAbsences         ScheduleAbsence[]
  driverRunLogs            DriverRunLog[]
  scheduleEditorPresences  ScheduleEditorPresence[]
  attendanceEntries        AttendanceEntry[]
  leaveRequests            LeaveRequest[]
  leaveBalances            LeaveBalance[]
  payTypes                 PayType[]
  allowanceTypes           AllowanceType[]
  leaveTypes               LeaveType[]
  companyHolidays          CompanyHoliday[]
  companyHolidayPayTypes   CompanyHolidayPayType[]
  employeeCompensations    EmployeeCompensation[]
  employeeAllowances       EmployeeAllowance[]
  payRuns                  PayRun[]
  payRunLines              PayRunLine[]
  mobileAccessTokens       EmployeeMobileAccessToken[]
  visaPeriods              VisaPeriod[]
  employeeDocuments        EmployeeDocument[]
  workforceExpertises      WorkforceExpertise[]
  employeeMetaOptions      EmployeeMetaOption[]
  materialWarehouseStocks  MaterialWarehouseStock[]
  materialAssemblyComponents MaterialAssemblyComponent[]
  tablePreferences         UserTablePreference[]
  liveUpdateEvents         LiveUpdateEvent[]
  stockExceptionApprovals  StockExceptionApproval[]
  stockCountSessions       StockCountSession[]
  domainEvents             DomainEvent[]
  businessDocuments        BusinessDocument[]
  workflowApprovals        WorkflowApproval[]
  quantityLogDaySubmissions QuantityLogDaySubmission[]
  quantityLogAdhocJobs      QuantityLogAdhocJob[]
  dispatchEntryRevisions    DispatchEntryRevision[]
  deliveryNotes             DeliveryNote[]
  deliveryNoteMaterialLines DeliveryNoteMaterialLine[]
}

model User {
  id                    String                      @id @default(cuid())
  name                  String
  email                 String                      @unique
  password              String?
  image                 String?
  signatureUrl          String?                     @db.Text
  isSuperAdmin          Boolean                     @default(false)
  isActive              Boolean                     @default(true)
  activeCompanyId       String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  activeCompany         Company?                    @relation("UserActiveCompany", fields: [activeCompanyId], references: [id])
  companyAccess         UserCompanyAccess[]
  performedTransactions Transaction[]               @relation("TransactionPerformedBy")
  uploadedMedia         MediaAsset[]                @relation("MediaAssetUploader")
  mobileAccessTokens    EmployeeMobileAccessToken[]
  tablePreferences      UserTablePreference[]
  /// When set, this login is the employee self-service account for HR portal
  linkedEmployeeId      String?                     @unique
  linkedEmployee        Employee?                   @relation("EmployeeUserLink", fields: [linkedEmployeeId], references: [id], onDelete: SetNull)
  domainEvents          DomainEvent[]               @relation("DomainEventActorUser")
  createdBusinessDocuments  BusinessDocument[]      @relation("BusinessDocumentCreatedBy")
  approvedBusinessDocuments BusinessDocument[]      @relation("BusinessDocumentApprovedBy")
  requestedWorkflowApprovals WorkflowApproval[]     @relation("WorkflowApprovalRequestedBy")
  decidedWorkflowApprovals   WorkflowApproval[]     @relation("WorkflowApprovalDecidedBy")
  quantityLogDaySubmissions  QuantityLogDaySubmission[]
  quantityLogAdhocJobsCreated QuantityLogAdhocJob[]
  dispatchEntryRevisionsWritten DispatchEntryRevision[] @relation("DispatchEntryRevisionActor")
  createdDeliveryNotes          DeliveryNote[]            @relation("DeliveryNoteCreatedBy")
  passwordResetTokens         PasswordResetToken[]
  reviewedLeaveRequests       LeaveRequest[]         @relation("LeaveRequestReviewedBy")
  scheduleEditorPresences     ScheduleEditorPresence[]

  @@index([activeCompanyId])
}

/// Global outbound email configuration (password reset, notifications).
model SystemEmailSettings {
  id          String   @id @default("global")
  provider    String   @default("env")
  config      Json     @default("{}")
  updatedAt   DateTime @updatedAt
  updatedById String?
}

/// One-time token for self-service password reset (hashed at rest).
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Uploaded file stored in Google Drive; usage tracked via MediaAssetLink (orphans = safe to delete).
/// `driveId` stores a viewer URL, Drive web URL, or bare file id — see `extractGoogleDriveFileId`.
model MediaAsset {
  id           String           @id @default(cuid())
  companyId    String
  driveId      String           @db.Text
  mimeType     String           @default("image/jpeg")
  fileName     String
  /// e.g. profile_image, signature, template, general
  category     String           @default("general")
  bytes        Int?
  uploadedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy   User?            @relation("MediaAssetUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  links        MediaAssetLink[]

  @@unique([companyId, driveId])
  @@index([companyId, category])
  @@index([companyId, createdAt])
}

/// Binds a media file to an app entity (one profile image per user, etc.).
model MediaAssetLink {
  id       String     @id @default(cuid())
  assetId  String
  kind     String
  entityId String
  asset    MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([kind, entityId])
  @@index([assetId])
}

model Role {
  id          String              @id @default(cuid())
  name        String              @unique
  slug        String              @unique
  permissions Json
  isSystem    Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  userAccess  UserCompanyAccess[]
}

model UserCompanyAccess {
  id        String  @id @default(cuid())
  userId    String
  companyId String
  roleId    String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role    @relation(fields: [roleId], references: [id])
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId, roleId])
  @@index([companyId])
  @@index([roleId])
  @@index([userId, companyId])
}

model UserTablePreference {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  key       String
  state     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId, key])
  @@index([companyId, key])
}

model LiveUpdateEvent {
  id        BigInt   @id @default(autoincrement())
  companyId String
  channel   String
  entity    String
  action    String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, channel, id])
  @@index([createdAt])
}

model GlobalSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DomainEvent {
  id            String   @id @default(cuid())
  companyId     String
  module        DomainModule
  eventType     String
  entityType    DomainEntityType
  entityId      String
  occurredAt    DateTime @default(now())
  actorUserId   String?
  correlationId String?
  payload       Json?
  createdAt     DateTime @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actorUser User?   @relation("DomainEventActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([companyId, module, occurredAt])
  @@index([companyId, entityType, entityId, occurredAt])
  @@index([correlationId])
}

model DomainEventTypeRegistry {
  id          String       @id @default(cuid())
  module      DomainModule
  eventType   String
  description String?      @db.Text
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([module, eventType])
  @@index([module, isActive])
}

model BusinessDocument {
  id            String                 @id @default(cuid())
  companyId     String
  docType       String
  docNumber     String
  docDate       DateTime
  status        BusinessDocumentStatus @default(DRAFT)
  sourceModule  String
  partyType     String?
  partyId       String?
  currencyCode  String?
  fxRate        Decimal?               @db.Decimal(18, 6)
  totals        Json?
  meta          Json?
  createdById   String?
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("BusinessDocumentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy   User?         @relation("BusinessDocumentApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  transactions Transaction[]
  stockBatches StockBatch[]

  @@unique([companyId, docType, docNumber])
  @@unique([companyId, id])
  @@index([companyId, docType, status, docDate])
  @@index([companyId, sourceModule, docDate])
  @@index([companyId, partyType, partyId])
}

model WorkflowApproval {
  id            String                 @id @default(cuid())
  companyId     String
  entityType    String
  entityId      String
  workflowType  String
  status        WorkflowApprovalStatus @default(PENDING)
  requestedById String?
  requestedAt   DateTime               @default(now())
  decidedById   String?
  decidedAt     DateTime?
  decisionNote  String?                @db.Text
  payload       Json?

  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requestedBy  User?   @relation("WorkflowApprovalRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  decidedBy    User?   @relation("WorkflowApprovalDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  @@unique([companyId, workflowType, entityType, entityId])
  @@index([companyId, status, requestedAt])
  @@index([companyId, workflowType, status])
}

model StockCountSession {
  id                              String                  @id @default(cuid())
  companyId                       String
  warehouseId                     String
  title                           String
  status                          StockCountSessionStatus @default(DRAFT)
  evidenceReference               String?
  evidenceNotes                   String?                 @db.Text
  notes                           String?                 @db.Text
  currentRevision                 Int                     @default(1)
  linkedAdjustmentApprovalId      String?
  linkedAdjustmentReferenceNumber String?
  createdById                     String?
  createdByName                   String?
  reviewedById                    String?
  reviewedByName                  String?
  reviewedAt                      DateTime?
  createdAt                       DateTime                @default(now())
  updatedAt                       DateTime                @updatedAt

  company   Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse Warehouse                 @relation(fields: [companyId, warehouseId], references: [companyId, id], onDelete: Restrict)
  lines     StockCountSessionLine[]
  revisions StockCountSessionRevision[]

  @@index([companyId, status, createdAt])
  @@index([companyId, warehouseId, status])
}

model StockCountSessionLine {
  id           String   @id @default(cuid())
  sessionId     String
  materialId   String
  materialName String
  unit         String
  warehouseId  String
  systemQty    Decimal  @default(0) @db.Decimal(18, 3)
  countedQty   Decimal? @db.Decimal(18, 3)
  varianceQty  Decimal  @default(0) @db.Decimal(18, 3)
  unitCost     Decimal  @default(0) @db.Decimal(18, 4)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  session StockCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sortOrder])
}

model StockCountSessionRevision {
  id             String   @id @default(cuid())
  sessionId       String
  revisionNumber Int
  action         String
  savedById      String?
  savedByName    String?
  snapshot       Json
  createdAt      DateTime @default(now())

  session StockCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, revisionNumber])
  @@index([createdAt])
}

model StockExceptionApproval {
  id              String                       @id @default(cuid())
  companyId       String
  exceptionType   StockExceptionType
  status          StockExceptionApprovalStatus @default(PENDING)
  referenceId     String
  referenceNumber String?
  reason          String                       @db.Text
  payload         Json?
  createdById     String?
  createdByName   String?
  createdAt       DateTime                     @default(now())
  decidedById     String?
  decidedByName   String?
  decidedAt       DateTime?
  decisionNote    String?                      @db.Text

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, exceptionType, referenceId])
  @@index([companyId, status, createdAt])
  @@index([companyId, exceptionType, createdAt])
}

model Material {
  id                       String                   @id @default(cuid())
  companyId                String
  name                     String
  description              String?                  @db.Text
  imageUrl                 String?
  attachmentUrl            String?
  attachmentName           String?
  attachmentMimeType       String?
  photoGallery             Json?
  documentFiles            Json?
  unit                     String
  category                 String?
  categoryId               String?
  warehouse                String?
  warehouseId              String?
  stockType                String
  allowNegativeConsumption Boolean                  @default(false)
  externalItemName         String?
  currentStock             Decimal                  @default(0) @db.Decimal(18, 3)
  reorderLevel             Decimal?                 @db.Decimal(18, 3)
  unitCost                 Decimal?                 @db.Decimal(18, 4)
  assemblyOutputQuantity   Decimal                  @default(1) @db.Decimal(18, 3)
  assemblyOverheadPercent  Decimal                  @default(0) @db.Decimal(8, 3)
  assemblyUseDynamicCost   Boolean                  @default(true)
  isActive                 Boolean                  @default(true)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  company                  Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryRef              Category?                @relation(fields: [companyId, categoryId], references: [companyId, id], onDelete: Restrict)
  stockBatches             StockBatch[]
  transactions             Transaction[]
  materialUoms             MaterialUom[]
  materialWarehouseStocks  MaterialWarehouseStock[]
  warehouseRef             Warehouse?               @relation(fields: [companyId, warehouseId], references: [companyId, id], onDelete: Restrict)
  assemblyComponents       MaterialAssemblyComponent[] @relation("AssemblyMaterial")
  usedInAssemblies         MaterialAssemblyComponent[] @relation("ComponentMaterial")
  finishedGoodTrackableLinks JobItemTrackableMaterialLink[] @relation("TrackableFinishedGoodMaterial")
  productionStockPostings  ProductionStockPosting[] @relation("ProductionPostingMaterial")
  deliveryNoteMaterialLines  DeliveryNoteMaterialLine[]

  @@unique([companyId, id])
  @@unique([companyId, name])
  @@index([companyId, isActive])
  @@index([companyId, categoryId])
  @@index([companyId, warehouseId])
}

model MaterialAssemblyComponent {
  id                  String   @id @default(cuid())
  companyId           String
  assemblyMaterialId  String
  componentMaterialId String
  quantity            Decimal  @db.Decimal(18, 3)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assemblyMaterial   Material @relation("AssemblyMaterial", fields: [companyId, assemblyMaterialId], references: [companyId, id], onDelete: Cascade)
  componentMaterial  Material @relation("ComponentMaterial", fields: [companyId, componentMaterialId], references: [companyId, id], onDelete: Restrict)

  @@unique([assemblyMaterialId, componentMaterialId])
  @@index([companyId, assemblyMaterialId])
  @@index([companyId, componentMaterialId])
}

/// Per-material UOM chain: exactly one base (parent null, factor 1). 1 of this row = factorToParent × 1 parent UOM.
model MaterialUom {
  id             String        @id @default(cuid())
  companyId      String
  materialId     String
  unitId         String
  isBase         Boolean       @default(false)
  parentUomId    String?
  factorToParent Float
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  material       Material      @relation(fields: [companyId, materialId], references: [companyId, id], onDelete: Cascade)
  unit           Unit          @relation(fields: [unitId], references: [id], onDelete: Restrict)
  parent         MaterialUom?  @relation("MaterialUomParent", fields: [parentUomId], references: [id], onDelete: Restrict)
  children       MaterialUom[] @relation("MaterialUomParent")

  @@unique([materialId, unitId])
  @@index([companyId, materialId])
}

model StockBatch {
  id                String             @id @default(cuid())
  companyId         String
  materialId        String
  warehouseId       String?
  batchNumber       String
  quantityReceived  Decimal            @db.Decimal(18, 3)
  quantityAvailable Decimal            @db.Decimal(18, 3)
  unitCost          Decimal            @db.Decimal(18, 4)
  totalCost         Decimal            @db.Decimal(18, 4)
  supplier          String?
  supplierId        String?
  receiptNumber     String?
  businessDocumentId String?
  receivedDate      DateTime
  expiryDate        DateTime?
  notes             String?            @db.Text
  meta              Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  material          Material           @relation(fields: [companyId, materialId], references: [companyId, id])
  warehouse         Warehouse?         @relation(fields: [companyId, warehouseId], references: [companyId, id], onDelete: Restrict)
  supplierRef       Supplier?          @relation(fields: [companyId, supplierId], references: [companyId, id], onDelete: Restrict)
  businessDocument  BusinessDocument?  @relation(fields: [companyId, businessDocumentId], references: [companyId, id], onDelete: SetNull)
  transactionLinks  TransactionBatch[]
  productionStockPostings ProductionStockPosting[]

  @@unique([companyId, batchNumber])
  @@index([companyId, materialId, receivedDate])
  @@index([companyId, materialId, quantityAvailable])
  @@index([companyId, warehouseId, materialId, receivedDate])
  @@index([receiptNumber])
  @@index([companyId, supplierId])
  @@index([companyId, businessDocumentId])
  @@index([materialId], map: "StockBatch_materialId_fkey")
}

model Transaction {
  id                  String             @id @default(cuid())
  companyId           String
  type                TransactionType
  materialId          String
  warehouseId         String?
  quantity            Decimal            @db.Decimal(18, 3)
  jobId               String?
  parentTransactionId String?
  counterpartCompany  String?
  notes               String?            @db.Text
  date                DateTime           @default(now())
  performedBy         String
  performedByUserId   String?
  performedByName     String?
  totalCost           Decimal            @default(0) @db.Decimal(18, 4)
  averageCost         Decimal            @default(0) @db.Decimal(18, 4)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  isDeliveryNote      Boolean            @default(false)
  signedCopyUrl       String?
  sourceModule        String             @default("stock")
  referenceType       String?
  referenceId         String?
  idempotencyKey      String?
  meta                Json?
  businessDocumentId  String?
  deliveryNoteId      String?
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job                 Job?               @relation(fields: [companyId, jobId], references: [companyId, id], onDelete: Restrict)
  material            Material           @relation(fields: [companyId, materialId], references: [companyId, id])
  warehouse           Warehouse?         @relation(fields: [companyId, warehouseId], references: [companyId, id], onDelete: Restrict)
  performedByUser     User?              @relation("TransactionPerformedBy", fields: [performedByUserId], references: [id], onDelete: SetNull)
  parent              Transaction?       @relation("TxParent", fields: [companyId, parentTransactionId], references: [companyId, id], onDelete: Restrict)
  children            Transaction[]      @relation("TxParent")
  batchesUsed         TransactionBatch[]
  productionStockPostings ProductionStockPosting[] @relation("ProductionPostingTransaction")
  productionStockReversals ProductionStockPosting[] @relation("ProductionPostingReversalTransaction")
  businessDocument    BusinessDocument?  @relation(fields: [companyId, businessDocumentId], references: [companyId, id], onDelete: SetNull)
  deliveryNote        DeliveryNote?      @relation(fields: [deliveryNoteId], references: [id], onDelete: SetNull)

  @@unique([companyId, id])
  @@index([companyId, date])
  @@index([companyId, jobId, materialId])
  @@index([companyId, materialId, type])
  @@index([companyId, warehouseId, materialId, date])
  @@index([companyId, parentTransactionId])
  @@index([performedByUserId])
  @@index([companyId, sourceModule, date])
  @@index([companyId, referenceType, referenceId])
  @@index([companyId, businessDocumentId])
  @@index([deliveryNoteId])
  @@index([jobId], map: "Transaction_jobId_fkey")
  @@index([materialId], map: "Transaction_materialId_fkey")
}

model TransactionBatch {
  id                String      @id @default(cuid())
  transactionId     String
  batchId           String
  batchNumber       String
  quantityFromBatch Decimal     @db.Decimal(18, 3)
  unitCost          Decimal     @db.Decimal(18, 4)
  costAmount        Decimal     @db.Decimal(18, 4)
  batch             StockBatch  @relation(fields: [batchId], references: [id])
  transaction       Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([batchId])
}

/// One printed delivery note; dispatch STOCK_OUT or subcontract transfer lines share `deliveryNoteId`.
model DeliveryNote {
  id           String        @id @default(cuid())
  companyId    String
  number       Int
  deliveryType DeliveryNoteType @default(DISPATCH)
  jobId        String?
  date         DateTime
  /// True when this delivery note was saved with no material STOCK_OUT lines (custom items / document only).
  materialDispatchSkipped Boolean @default(false)
  /// Structured custom line items for printing (name, description, unit, qty).
  customItemsJson Json?
  /// User-authored notes for the document, without composed transaction headers.
  documentNotes   String?      @db.Text
  /// Contact person selected for this delivery note (may differ from job primary contact).
  contactPerson   String?
  /// Subcontract: supplier receiving material for external processing.
  supplierId          String?
  sourceWarehouseId   String?
  targetWarehouseId   String?
  transitStatus       DeliveryNoteTransitStatus?
  /// Optional planning reference; does not consume job stock for subcontract notes.
  referenceJobId      String?
  createdByUserId     String?
  createdByName       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job          Job?          @relation(fields: [companyId, jobId], references: [companyId, id], onDelete: SetNull)
  supplier     Supplier?     @relation(fields: [companyId, supplierId], references: [companyId, id], onDelete: SetNull)
  sourceWarehouse Warehouse? @relation("DeliveryNoteSourceWarehouse", fields: [companyId, sourceWarehouseId], references: [companyId, id], onDelete: SetNull)
  targetWarehouse Warehouse? @relation("DeliveryNoteTargetWarehouse", fields: [companyId, targetWarehouseId], references: [companyId, id], onDelete: SetNull)
  referenceJob Job?          @relation("DeliveryNoteReferenceJob", fields: [companyId, referenceJobId], references: [companyId, id], onDelete: SetNull)
  createdByUser User?        @relation("DeliveryNoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  transactions Transaction[]
  materialLines DeliveryNoteMaterialLine[]

  @@unique([companyId, number])
  @@index([companyId, jobId])
  @@index([companyId, date])
  @@index([companyId, deliveryType])
  @@index([companyId, supplierId])
  @@index([companyId, transitStatus])
}

/// Subcontract delivery note material lines with issued/received quantities (base UOM).
model DeliveryNoteMaterialLine {
  id                  String   @id @default(cuid())
  companyId           String
  deliveryNoteId      String
  materialId          String
  quantityUomId       String?
  issuedQty           Decimal  @db.Decimal(18, 3)
  receivedQty         Decimal  @default(0) @db.Decimal(18, 3)
  sourceWarehouseId   String
  targetWarehouseId   String
  issueTransferOutId  String?
  issueTransferInId   String?
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deliveryNote        DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  material            Material @relation(fields: [companyId, materialId], references: [companyId, id], onDelete: Restrict)
  sourceWarehouse     Warehouse @relation("SubcontractLineSourceWarehouse", fields: [companyId, sourceWarehouseId], references: [companyId, id], onDelete: Restrict)
  targetWarehouse     Warehouse @relation("SubcontractLineTargetWarehouse", fields: [companyId, targetWarehouseId], references: [companyId, id], onDelete: Restrict)

  @@index([deliveryNoteId, sortOrder])
  @@index([companyId, materialId])
}

/// Append-only audit of job dispatch worksheet / delivery-note material lines saved via batch STOCK_OUT (per job + calendar day).
model DispatchEntryRevision {
  id              String   @id @default(cuid())
  companyId       String
  jobId           String
  /// Calendar day key `YYYY-MM-DD` (same as dispatch-entry query), not timezone-shifted storage.
  postingDateKey  String
  source          String   @default("WORKSHEET")
  action          String
  actorUserId     String?
  actorName       String
  linesBefore     Json?
  linesAfter      Json
  changeSummary   Json?
  notesSnippet    String?  @db.VarChar(500)
  createdAt       DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job     Job     @relation(fields: [companyId, jobId], references: [companyId, id], onDelete: Cascade)
  actor   User?   @relation("DispatchEntryRevisionActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([companyId, jobId, postingDateKey])
  @@index([companyId, createdAt])
}

model Job {
  id                     String                 @id @default(cuid())
  companyId              String
  /// External parent-job identifier from Project Management system
  externalJobId          String?
  jobNumber              String
  customerId             String
  description            String?                @db.Text
  site                   String?
  address                String?                @db.Text
  locationName           String?
  locationLat            Float?
  locationLng            Float?
  status                 JobStatus              @default(ACTIVE)
  startDate              DateTime?
  endDate                DateTime?
  quotationNumber        String?
  quotationDate          DateTime?
  lpoNumber              String?
  lpoDate                DateTime?
  lpoValue               Decimal?               @db.Decimal(18, 2)
  projectName            String?
  projectDetails         String?                @db.Text
  /// e.g. Fit-out, Maintenance, Civil works
  projectType            String?                @db.VarChar(120)
  /// Quantity or area scope for the job (e.g. 1200 sqm, 50 nos)
  projectQtyArea         String?                @db.VarChar(120)
  /// Primary site/contact name (same idea as Customer.contactPerson)
  contactPerson          String?
  salesPerson            String?
  jobWorkValue           Decimal?               @db.Decimal(18, 2)
  finishedGoods          Json?
  source                 JobRecordSource        @default(LOCAL)
  externalUpdatedAt      DateTime?
  createdBy              String
  parentJobId            String?
  /// Costing / execution: one schedule & manual progress for the whole job (not per budget line).
  executionProgressStatus   JobItemProgressStatus @default(NOT_STARTED)
  executionProgressPercent  Decimal               @default(0) @db.Decimal(5, 2)
  executionPlannedStartDate DateTime?             @db.Date
  executionPlannedEndDate   DateTime?             @db.Date
  executionActualStartDate  DateTime?             @db.Date
  executionActualEndDate    DateTime?             @db.Date
  executionProgressNote     String?               @db.Text
  executionProgressUpdatedAt DateTime?
  /// Temporary job number until a formal customer job number is issued.
  isProvisional            Boolean                @default(false)
  confirmedAt              DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  company                Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer               Customer               @relation(fields: [companyId, customerId], references: [companyId, id])
  parentJob              Job?                   @relation("JobVariations", fields: [companyId, parentJobId], references: [companyId, id], onDelete: Cascade)
  variations             Job[]                  @relation("JobVariations")
  transactions           Transaction[]
  lpoValueHistory        JobLpoValueHistory[]
  jobNumberHistory       JobNumberHistory[]
  contacts               JobContact[]
  jobItems               JobItem[]
  jobCostingSnapshots    JobCostingSnapshot[]
  requiredExpertiseLinks JobRequiredExpertise[]
  workAssignments        WorkAssignment[]
  quantityLogAdhocJobs     QuantityLogAdhocJob[]
  dispatchEntryRevisions   DispatchEntryRevision[]
  deliveryNotes            DeliveryNote[]
  referenceDeliveryNotes   DeliveryNote[] @relation("DeliveryNoteReferenceJob")

  @@unique([companyId, id])
  @@unique([companyId, jobNumber])
  @@unique([companyId, externalJobId])
  @@index([companyId, status])
  @@index([companyId, customerId])
  @@index([companyId, parentJobId])
  @@index([companyId, source])
  @@index([companyId, isProvisional])
}

/// Marks that the daily quantity log was finalized for this calendar day — no new progress entries for this date.
model QuantityLogDaySubmission {
  id            String   @id @default(cuid())
  companyId     String
  workDate      DateTime @db.Date
  submittedAt   DateTime @default(now())
  submittedById String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  submittedBy   User     @relation(fields: [submittedById], references: [id], onDelete: Restrict)

  @@unique([companyId, workDate])
  @@index([companyId, workDate])
}

/// Jobs attached to a quantity log for a day without an HR schedule row (ad-hoc logging).
model QuantityLogAdhocJob {
  id          String   @id @default(cuid())
  companyId   String
  workDate    DateTime @db.Date
  jobId       String
  createdById String
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job         Job      @relation(fields: [companyId, jobId], references: [companyId, id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([companyId, workDate, jobId])
  @@index([companyId, workDate])
}

model JobContact {
  id          String   @id @default(cuid())
  companyId   String
  jobId       String
  label       String?
  name        String
  email       String?
  number      String?
  designation String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job     Job     @relation(fields: [companyId, jobId], references: [companyId, id], onDelete: Cascade)

  @@index([companyId, jobId, sortOrder])
}

model WorkforceExpertise {
  id        String   @id @default(cuid())
  companyId String
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobLinks JobRequiredExpertise[]

  @@unique([companyId, id])
  @@unique([companyId, name])
  @@index([companyId, isActive, sortOrder])
}

enum EmployeeMetaKind {
  DESIGNATION
  DEPARTMENT
  EMPLOYMENT_TYPE
}

model EmployeeMetaOption {
  id        String           @id @default(cuid())
  companyId String
  kind      EmployeeMetaKind
  name      String
  isActive  Boolean          @default(true)
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, id])
  @@unique([companyId, kind, name])
  @@index([companyId, kind, isActive, sortOrder])
}

model JobRequiredExpertise {
  id          String   @id @default(cuid())
  companyId   String
  jobId       String
  expertiseId String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job       Job                @relation(fields: [companyId, jobId], references: [companyId, id], onDelete: Cascade)
  expertise WorkforceExpertise @relation(fields: [companyId, expertiseId], references: [companyId, id], onDelete: Cascade)

  @@unique([jobId, expertiseId])
  @@index([companyId, jobId, sortOrder])
  @@index([companyId, expertiseId])
}

/// One-way inbound credential for integrations; only hash is stored.
model ApiCredential {
  id             String    @id @default(cuid())
  companyId      String
  label          String
  keyPrefix      String
  keyHash        String
  /// Hostnames allowed to call integration APIs (Origin / Referer). Empty = no restriction.
  allowedDomains Json?
  scopes         Json?
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, keyPrefix])
  @@index([companyId, revokedAt])
}

/// Audit trail for LPO value changes (manual or external sync).
model JobLpoValueHistory {
  id            String   @id @default(cuid())
  companyId     String
  jobId         String
  previousValue Decimal? @db.Decimal(18, 2)
  newValue      Decimal? @db.Decimal(18, 2)
  changedBy     String
  source        String   @default("manual")
  note          String?
  createdAt     DateTime @default(now())
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job           Job      @relation(fields: [companyId, jobId], references: [companyId, id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, jobId, createdAt])
}

/// Audit trail when a provisional job number is confirmed or a job number is reassigned.
model JobNumberHistory {
  id                 String   @id @default(cuid())
  companyId          String
  jobId              String
  previousJobNumber  String
  newJobNumber       String
  previousCustomerId String
  newCustomerId      String
  changedBy          String
  note               String?  @db.Text
  createdAt          DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job     Job     @relation(fields: [companyId, jobId], references: [companyId, id], onDelete: Cascade)

  @@index([companyId, jobId, createdAt])
  @@index([companyId, createdAt])
}

model IntegrationSyncLog {
  id             String   @id @default(cuid())
  companyId      String
  credentialId   String?
  idempotencyKey String?
  requestHash    String?
  direction      String   @default("inbound")
  entityType     String   @default("job")
  entityKey      String?
  status         String   @default("success")
  httpStatus     Int?
  requestBody    Json?
  responseBody   Json?
  errorMessage   String?  @db.Text
  createdAt      DateTime @default(now())
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, idempotencyKey])
  @@index([companyId, createdAt])
  @@index([companyId, status])
  @@index([credentialId])
}

model Customer {
  id                    String            @id @default(cuid())
  companyId             String
  name                  String
  contactPerson         String?
  phone                 String?
  email                 String?
  address               String?           @db.Text
  isActive              Boolean           @default(true)
  /// Created in AMFGI vs imported from external party-lists API
  source                PartyRecordSource @default(LOCAL)
  /// Remote party id from Accounts Helper (clients.php id) when source = PARTY_API_SYNC
  externalPartyId       Int?
  externalSyncedAt      DateTime?
  tradeLicenseNumber    String?
  tradeLicenseAuthority String?           @db.VarChar(255)
  tradeLicenseExpiry    DateTime?
  trnNumber             String?
  trnExpiry             DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  company               Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contacts              CustomerContact[]
  jobs                  Job[]

  @@unique([companyId, id])
  @@unique([companyId, externalPartyId])
  @@index([companyId, name])
  @@index([companyId, isActive])
  @@index([companyId, source])
}

model CustomerContact {
  id                String   @id @default(cuid())
  companyId         String
  customerId        String
  externalContactId Int?
  contactName       String
  email             String?
  phone             String?
  sortOrder         Int      @default(0)
  externalCreatedAt String?  @db.VarChar(80)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [companyId, customerId], references: [companyId, id], onDelete: Cascade)

  @@index([companyId, customerId, sortOrder])
  @@index([companyId, externalContactId])
}

model Supplier {
  id                    String            @id @default(cuid())
  companyId             String
  name                  String
  contactPerson         String?
  email                 String?
  phone                 String?
  address               String?           @db.Text
  city                  String?
  country               String?
  isActive              Boolean           @default(true)
  source                PartyRecordSource @default(LOCAL)
  externalPartyId       Int?
  externalSyncedAt      DateTime?
  tradeLicenseNumber    String?
  tradeLicenseAuthority String?           @db.VarChar(255)
  tradeLicenseExpiry    DateTime?
  trnNumber             String?
  trnExpiry             DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  company               Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contacts              SupplierContact[]
  stockBatches          StockBatch[]
  deliveryNotes         DeliveryNote[]

  @@unique([companyId, id])
  @@unique([companyId, externalPartyId])
  @@index([companyId, name])
  @@index([companyId, isActive])
  @@index([companyId, source])
}

model SupplierContact {
  id                String   @id @default(cuid())
  companyId         String
  supplierId        String
  externalContactId Int?
  contactName       String
  email             String?
  phone             String?
  sortOrder         Int      @default(0)
  externalCreatedAt String?  @db.VarChar(80)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [companyId, supplierId], references: [companyId, id], onDelete: Cascade)

  @@index([companyId, supplierId, sortOrder])
  @@index([companyId, externalContactId])
}

model Unit {
  id           String        @id @default(cuid())
  companyId    String
  name         String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  materialUoms MaterialUom[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model Category {
  id        String     @id @default(cuid())
  companyId String
  name      String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  materials Material[]

  @@unique([companyId, id])
  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model Warehouse {
  id                      String                   @id @default(cuid())
  companyId               String
  name                    String
  location                String?
  isActive                Boolean                  @default(true)
  isSystem                Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  company                 Company                  @relation("CompanyWarehouses", fields: [companyId], references: [id], onDelete: Cascade)
  materials               Material[]
  fallbackForCompanies    Company[]                @relation("CompanyStockFallbackWarehouse")
  stockBatches            StockBatch[]
  transactions            Transaction[]
  materialWarehouseStocks MaterialWarehouseStock[]
  stockCountSessions      StockCountSession[]
  finishedGoodTrackableLinks JobItemTrackableMaterialLink[] @relation("TrackableFinishedGoodWarehouse")
  productionStockPostings ProductionStockPosting[] @relation("ProductionPostingWarehouse")
  deliveryNoteSources      DeliveryNote[] @relation("DeliveryNoteSourceWarehouse")
  deliveryNoteTargets      DeliveryNote[] @relation("DeliveryNoteTargetWarehouse")
  subcontractLineSources   DeliveryNoteMaterialLine[] @relation("SubcontractLineSourceWarehouse")
  subcontractLineTargets   DeliveryNoteMaterialLine[] @relation("SubcontractLineTargetWarehouse")

  @@unique([companyId, id])
  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model MaterialWarehouseStock {
  companyId    String
  materialId   String
  warehouseId  String
  currentStock Decimal  @default(0) @db.Decimal(18, 3)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  material  Material  @relation(fields: [companyId, materialId], references: [companyId, id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [companyId, warehouseId], references: [companyId, id], onDelete: Cascade)

  @@id([companyId, materialId, warehouseId])
  @@index([companyId, warehouseId])
}

model MaterialLog {
  id         String            @id @default(cuid())
  companyId  String
  materialId String
  action     MaterialLogAction
  changes    Json
  changedBy  String
  timestamp  DateTime          @default(now())

  @@index([companyId, materialId, timestamp])
}

model PriceLog {
  id            String      @id @default(cuid())
  companyId     String
  materialId    String
  previousPrice Decimal     @db.Decimal(18, 4)
  currentPrice  Decimal     @db.Decimal(18, 4)
  source        PriceSource
  changedBy     String
  billId        String?
  notes         String?     @db.Text
  timestamp     DateTime    @default(now())

  @@index([companyId, materialId, timestamp])
}

model FormulaLibrary {
  id                  String   @id @default(cuid())
  companyId           String
  name                String
  slug                String
  fabricationType     String
  description         String?  @db.Text
  specificationSchema Json?
  formulaConfig       Json
  isActive            Boolean  @default(true)
  createdBy           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company  Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobItems JobItem[]
  versions FormulaLibraryVersion[]

  @@unique([companyId, id])
  @@unique([companyId, slug])
  @@index([companyId, fabricationType, isActive])
}

model FormulaLibraryVersion {
  id               String   @id @default(cuid())
  companyId        String
  formulaLibraryId String
  versionNumber    Int
  name             String
  slug             String
  fabricationType  String
  description      String?  @db.Text
  specificationSchema Json?
  formulaConfig    Json
  changeNote       String?  @db.Text
  createdBy        String
  createdAt        DateTime @default(now())

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  formulaLibrary FormulaLibrary @relation(fields: [companyId, formulaLibraryId], references: [companyId, id], onDelete: Cascade)

  @@unique([companyId, id])
  @@unique([companyId, formulaLibraryId, versionNumber])
  @@index([companyId, formulaLibraryId, createdAt])
}

model JobItem {
  id               String   @id @default(cuid())
  companyId        String
  jobId            String
  formulaLibraryId String?
  name             String
  description      String?  @db.Text
  specifications   Json
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  progressStatus   JobItemProgressStatus @default(NOT_STARTED)
  progressPercent  Decimal  @default(0) @db.Decimal(5, 2)
  trackingItems    Json?
  trackingEnabled  Boolean  @default(false)
  trackingLabel    String?  @db.VarChar(120)
  trackingUnit     String?  @db.VarChar(40)
  trackingTargetValue Decimal? @db.Decimal(18, 3)
  trackingSourceKey String? @db.VarChar(180)
  plannedStartDate DateTime? @db.Date
  plannedEndDate   DateTime? @db.Date
  actualStartDate  DateTime? @db.Date
  actualEndDate    DateTime? @db.Date
  progressNote     String?  @db.Text
  progressUpdatedAt DateTime?
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job               Job                 @relation(fields: [companyId, jobId], references: [companyId, id], onDelete: Cascade)
  formulaLibrary    FormulaLibrary?     @relation(fields: [companyId, formulaLibraryId], references: [companyId, id], onDelete: Restrict)
  assignedEmployees JobItemAssignment[]
  progressEntries   JobItemProgressEntry[]
  trackableMaterialLinks JobItemTrackableMaterialLink[]
  productionStockPostings ProductionStockPosting[]

  @@unique([companyId, id])
  @@index([companyId, jobId, isActive])
  @@index([companyId, formulaLibraryId])
}

model JobItemProgressEntry {
  id         String   @id @default(cuid())
  companyId  String
  jobItemId  String
  trackerId  String?
  entryDate  DateTime @db.Date
  quantity   Decimal  @db.Decimal(18, 3)
  note       String?  @db.Text
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobItem JobItem @relation(fields: [companyId, jobItemId], references: [companyId, id], onDelete: Cascade)

  @@unique([companyId, id])
  @@index([companyId, jobItemId, trackerId, entryDate])
}

model JobItemTrackableMaterialLink {
  id          String   @id @default(cuid())
  companyId   String
  jobItemId   String
  trackerId   String
  materialId  String
  warehouseId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobItem       JobItem   @relation(fields: [companyId, jobItemId], references: [companyId, id], onDelete: Cascade)
  material      Material  @relation("TrackableFinishedGoodMaterial", fields: [companyId, materialId], references: [companyId, id], onDelete: Restrict)
  warehouse     Warehouse @relation("TrackableFinishedGoodWarehouse", fields: [companyId, warehouseId], references: [companyId, id], onDelete: Restrict)
  stockPostings ProductionStockPosting[]

  @@unique([companyId, jobItemId, trackerId])
  @@index([companyId, materialId])
  @@index([companyId, warehouseId])
}

model ProductionStockPosting {
  id          String   @id @default(cuid())
  companyId   String
  progressEntryId String
  jobItemId   String
  trackerId   String
  trackableMaterialLinkId String
  materialId  String
  warehouseId String
  transactionId String
  reversalTransactionId String?
  stockBatchId String
  quantity    Decimal  @db.Decimal(18, 3)
  status      ProductionStockPostingStatus @default(POSTED)
  postedAt    DateTime @default(now())
  reversedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobItem       JobItem   @relation(fields: [companyId, jobItemId], references: [companyId, id], onDelete: Restrict)
  trackableMaterialLink JobItemTrackableMaterialLink @relation(fields: [trackableMaterialLinkId], references: [id], onDelete: Restrict)
  material      Material  @relation("ProductionPostingMaterial", fields: [companyId, materialId], references: [companyId, id], onDelete: Restrict)
  warehouse     Warehouse @relation("ProductionPostingWarehouse", fields: [companyId, warehouseId], references: [companyId, id], onDelete: Restrict)
  transaction   Transaction @relation("ProductionPostingTransaction", fields: [companyId, transactionId], references: [companyId, id], onDelete: Restrict)
  reversalTransaction Transaction? @relation("ProductionPostingReversalTransaction", fields: [companyId, reversalTransactionId], references: [companyId, id], onDelete: Restrict)
  stockBatch    StockBatch @relation(fields: [stockBatchId], references: [id], onDelete: Restrict)

  @@unique([companyId, progressEntryId])
  @@index([companyId, jobItemId, trackerId])
  @@index([companyId, materialId, warehouseId])
  @@index([companyId, transactionId])
  @@index([companyId, stockBatchId])
}

model JobCostingSnapshot {
  id                 String   @id @default(cuid())
  companyId          String
  jobId              String
  versionNumber      Int
  status             JobCostingSnapshotStatus @default(SAVED)
  pricingMode        String
  postingDate        DateTime
  jobItemIds         Json?
  customUnitCosts    Json?
  pricingSnapshots   Json
  result             Json
  totalQuotedMaterialCost   Decimal @db.Decimal(18, 4)
  totalActualMaterialCost   Decimal @db.Decimal(18, 4)
  totalEstimatedCompletionDays Decimal @db.Decimal(18, 4)
  note               String?  @db.Text
  createdBy          String
  approvedBy         String?
  approvedAt         DateTime?
  createdAt          DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job     Job     @relation(fields: [companyId, jobId], references: [companyId, id], onDelete: Cascade)

  @@unique([companyId, id])
  @@unique([companyId, jobId, versionNumber])
  @@index([companyId, jobId, createdAt])
}

enum JobItemProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum ProductionStockPostingStatus {
  POSTED
  REVERSED
}

enum JobCostingSnapshotStatus {
  SAVED
  APPROVED
  SUPERSEDED
}

