{
	"name": "amfgi-erp",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"postinstall": "prisma generate",
		"dev": "prisma generate && next dev",
		"build": "prisma generate && node --max-old-space-size=3072 ./node_modules/next/dist/bin/next build",
		"build:deploy": "node --max-old-space-size=1536 ./node_modules/next/dist/bin/next build",
		"start": "next start",
		"lint": "eslint",
		"typecheck": "node --max-old-space-size=3072 ./node_modules/typescript/bin/tsc --noEmit",
		"typecheck:tests": "node --max-old-space-size=3072 ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.jest.json",
		"seed": "npx tsx scripts/seed.ts",
		"seed:production": "npx tsx scripts/seed-production.ts",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"pri": "prisma studio",
		"vercel:whoami": "vercel whoami",
		"vercel:deploy": "vercel deploy --yes",
		"vercel:deploy:with-check": "npm run typecheck && npm run vercel:deploy",
		"vercel:deploy:prod": "vercel deploy --prod --yes",
		"prisma:generate": "prisma generate"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/utilities": "^3.2.2",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-dropdown-menu": "^2.1.4",
		"@radix-ui/react-separator": "^1.1.0",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tooltip": "^1.1.6",
		"@reduxjs/toolkit": "^2.11.2",
		"bcryptjs": "^3.0.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"googleapis": "^171.4.0",
		"lucide-react": "^0.469.0",
		"next": "^16.2.6",
		"next-auth": "^5.0.0-beta.30",
		"nodemailer": "^8.0.7",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-hot-toast": "^2.6.0",
		"react-redux": "^9.2.0",
		"tailwind-merge": "^3.6.0",
		"xlsx": "^0.18.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4",
		"@types/bcryptjs": "^2.4.6",
		"@types/jest": "^29.5.14",
		"@types/node": "^20",
		"@types/nodemailer": "^8.0.0",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"dotenv": "^17.4.1",
		"eslint": "^9",
		"eslint-config-next": "16.2.2",
		"jest": "^29.7.0",
		"prisma": "^7.8.0",
		"shadcn": "^4.7.0",
		"tailwindcss": "^4",
		"ts-jest": "^29.4.5",
		"tsx": "^4.21.0",
		"typescript": "^5"
	},
	"prisma": {
		"schema": "prisma/schema.prisma",
		"engineType": "library",
		"binaryTargets": [
			"native",
			"debian-openssl-1.1.x",
			"debian-openssl-3.0.x"
		]
	}
}